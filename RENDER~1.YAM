services:
  - type: web
    name: lily-backend
    env: python
    plan: free
    buildCommand: "pip install -r requirements_backend.txt"
    startCommand: "uvicorn app:app --host 0.0.0.0 --port 8000"
    envVars:
      - key: PYTHON_VERSION
        value: 3.11.0
      - key: DATABASE_URL
        fromDatabase:
          name: lily-db
          property: connectionString
      - key: CLAUDE_API_KEY
        sync: false

  - type: pserv
    name: lily-db
    ipAllowList: []
    plan: free
    postgresVersion: 15
